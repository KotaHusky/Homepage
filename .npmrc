# @kotahusky scope is published to / installed from GitHub Packages.
# Auth (NODE_AUTH_TOKEN / a PAT with read:packages) is supplied by the
# environment — in CI via actions/setup-node, locally via your ~/.npmrc.
# In this repo @kotahusky/ui resolves to the local workspace, not the registry.
@kotahusky:registry=https://npm.pkg.github.com
