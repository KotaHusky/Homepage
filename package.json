{
  "name": "homepage",
  "version": "2.1.0",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "serve": "npx next start",
    "serve:static-export": "next build && next export && npx serve@latest out -l 3000",
    "build": "next build",
    "lint": "eslint .",
    "start": "npx next start",
    "start:docker-clean-build": "docker build -t homepage:latest .;docker run -p 3000:3000 homepage:latest",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "npm@9.6.7",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@nauverse/react-aurora-background": "^1.0.12",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "@nauverse/react-aurora-background": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.18",
